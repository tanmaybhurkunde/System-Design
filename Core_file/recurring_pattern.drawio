                <UserObject label="&lt;h1&gt;&lt;font style=&quot;font-size: 48px;&quot; face=&quot;Times New Roman&quot;&gt;🏗️ System Design Patterns&lt;br&gt;Building Blocks of Large Systems&lt;/font&gt;&lt;/h1&gt;" mermaidId="n:A" mermaidBaseStyle="html=1;whiteSpace=wrap;strokeWidth=4;fillColor=#1a1a2e;strokeColor=#e94560;fontColor=#ffffff;fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;" mermaidBaseValue="🏗️ System Design Patterns&#xa;Building Blocks of Large Systems" id="11">
