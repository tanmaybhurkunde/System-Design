                <UserObject label="&lt;font style=&quot;font-size: 24px;&quot;&gt;📱 Feed Systems&lt;br&gt;&lt;br&gt;📌 Examples:&lt;br&gt;• Facebook Feed&lt;br&gt;• Instagram Feed&lt;br&gt;• LinkedIn Feed&lt;br&gt;• Twitter Timeline&lt;br&gt;&lt;br&gt;⚠️ Core Challenge:&lt;br&gt;• Ranking (Relevance Algorithm)&lt;br&gt;• Aggregation (Content Mix)&lt;br&gt;• Massive Reads (Millions of users)&lt;br&gt;&lt;br&gt;📦 Main Discussion:&lt;br&gt;• Fanout (Push vs Pull vs Hybrid)&lt;br&gt;• Caching (Redis, CDN)&lt;br&gt;• Feed Generation (Pre-computation)&lt;br&gt;• Personalization (ML Ranking)&lt;br&gt;• Pagination (Cursor-based)&lt;/font&gt;" mermaidId="n:E" mermaidBaseStyle="html=1;whiteSpace=wrap;strokeWidth=2;fillColor=#0f3460;strokeColor=#e94560;fontColor=#ffffff;fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;" mermaidBaseValue="📱 Feed Systems&#xa;&#xa;📌 Examples:&#xa;• Facebook Feed&#xa;• Instagram Feed&#xa;• LinkedIn Feed&#xa;• Twitter Timeline&#xa;&#xa;⚠️ Core Challenge:&#xa;• Ranking (Relevance Algorithm)&#xa;• Aggregation (Content Mix)&#xa;• Massive Reads (Millions of users)&#xa;&#xa;📦 Main Discussion:&#xa;• Fanout (Push vs Pull vs Hybrid)&#xa;• Caching (Redis, CDN)&#xa;• Feed Generation (Pre-computation)&#xa;• Personalization (ML Ranking)&#xa;• Pagination (Cursor-based)" id="15">
                    <mxCell style="html=1;whiteSpace=wrap;strokeWidth=2;fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;labelBackgroundColor=none;opacity=70;rounded=1;" vertex="1" parent="2">
