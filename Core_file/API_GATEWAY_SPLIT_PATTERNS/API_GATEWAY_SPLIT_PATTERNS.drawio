                <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;flowchart TD\n    subgraph API[\&quot;API Gateway Split Patterns\&quot;]\n        A[\&quot;Different ways to split API Gateways\\nbased on traffic, domain, and scale requirements\&quot;]\n    end\n\n    %% Pattern 1: Domain-Based Split\n    subgraph BOUNDED[\&quot;Pattern 1: Domain-Based Split\&quot;]\n        B1[\&quot;Load Balancer\&quot;]\n        B1 --&gt; B2[\&quot;Auth Gateway\\n/login\\n/signup\\n/logout\\n/refresh-token\&quot;]\n        B1 --&gt; B3[\&quot;Game Gateway\\n/join-match\\n/move-token\\n/room\\n/game-state\&quot;]\n        B1 --&gt; B4[\&quot;Admin Gateway\\n/ban-user\\n/create-tournament\\n/moderate\\n/analytics\&quot;]\n    end\n\n    %% Pattern 2: Internal vs External\n    subgraph EXTERNAL[\&quot;Pattern 2: Internal vs External\&quot;]\n        E1[\&quot;Load Balancer\&quot;]\n        E1 --&gt; E2[\&quot;External Gateway\\nMobile App\\nWeb App\\nThird-party APIs\&quot;]\n        E1 --&gt; E3[\&quot;Internal Gateway\\nService-to-Service\\nAuth Service\\nPayment Service\\nAnalytics Service\&quot;]\n    end\n\n    %% Pattern 3: Read vs Write\n    subgraph READWRITE[\&quot;Pattern 3: Read vs Write\&quot;]\n        R1[\&quot;Load Balancer\&quot;]\n        R1 --&gt; R2[\&quot;Read Gateway\\nHigh Volume:\\nGET /leaderboard\\nGET /profile\\nGET /feed\\nGET /search\&quot;]\n        R1 --&gt; R3[\&quot;Write Gateway\\nLower Volume:\\nPOST /move\\nPOST /payment\\nPUT /profile\\nDELETE /item\&quot;]\n    end\n\n    %% Pattern 4: Geographic Split\n    subgraph GEO[\&quot;Pattern 4: Geographic Split\&quot;]\n        G1[\&quot;Global Load Balancer\&quot;]\n        G1 --&gt; G2[\&quot;India Gateway\\nMumbai Region\\nap-south-1\\nLow latency for India\&quot;]\n        G1 --&gt; G3[\&quot;US Gateway\\nus-east-1\\nus-west-2\\nNorth America traffic\&quot;]\n        G1 --&gt; G4[\&quot;Europe Gateway\\neu-west-1\\neu-central-1\\nEU compliance (GDPR)\&quot;]\n    end\n\n    %% Pattern 5: Protocol-Based Split\n    subgraph PROTOCOL[\&quot;Pattern 5: Protocol-Based Split\&quot;]\n        P1[\&quot;Load Balancer\&quot;]\n        P1 --&gt; P2[\&quot;HTTP Gateway\\nCharacteristics:\\nShort-lived connections\\nStateless\\nREST APIs\\nRequest-Response\\nScale: Pods\\nExamples:\\nREST APIs\\nFile uploads\\nHealth checks\&quot;]\n        P1 --&gt; P3[\&quot;WebSocket Gateway\\nCharacteristics:\\nLong-lived connections\\nStateful\\nReal-time\\nPub/Sub\\nScale: Connections\\nExamples:\\nChat\\nGaming\\nLive updates\\nCollaborative editing\&quot;]\n    end\n\n    %% Quick Comparison\n    subgraph COMPARISON[\&quot;Quick Comparison\&quot;]\n        C1[\&quot;| Pattern | When to Use |\\n|---------|-------------|\\n| Domain-Based | Different business domains |\\n| Internal/External | Security separation |\\n| Read/Write | Massive scale |\\n| Geographic | Global users |\\n| Protocol-Based | Different traffic types |\&quot;]\n    end\n\n    %% Connections\n    API --&gt; BOUNDED\n    API --&gt; EXTERNAL\n    API --&gt; READWRITE\n    API --&gt; GEO\n    API --&gt; PROTOCOL\n    API --&gt; COMPARISON\n&quot;&#xa;}" id="2">
                    <mxCell style="shape=image;noLabel=1;verticalAlign=top;imageAspect=1;image=data:image/svg+xml,;" vertex="1" parent="1">
