                <UserObject label="&lt;font style=&quot;&quot;&gt;&lt;b style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 36px;&quot;&gt;📢 Publish-Subscribe (Pub/Sub)&lt;br&gt;&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Producers don&#39;t know consumers&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Architecture:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Publisher → Topic → Subscribers&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;📌 Example:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;PLAYER_JOINED event&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Subscribers:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Chat Service&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Notification Service&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Analytics Service&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;✅ Advantages:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Decoupled&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Scalable&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Flexible&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;❌ Disadvantages:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Message ordering issues&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• At-least-once delivery&lt;/span&gt;&lt;/font&gt;" mermaidId="n:H" mermaidBaseStyle="html=1;whiteSpace=wrap;strokeWidth=2;fillColor=#0f3460;strokeColor=#e94560;fontColor=#ffffff;fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;" mermaidBaseValue="📢 Publish-Subscribe (Pub/Sub)&#xa;&#xa;Producers don&#39;t know consumers&#xa;&#xa;Architecture:&#xa;Publisher → Topic → Subscribers&#xa;&#xa;📌 Example:&#xa;PLAYER_JOINED event&#xa;Subscribers:&#xa;• Chat Service&#xa;• Notification Service&#xa;• Analytics Service&#xa;&#xa;✅ Advantages:&#xa;• Decoupled&#xa;• Scalable&#xa;• Flexible&#xa;&#xa;❌ Disadvantages:&#xa;• Message ordering issues&#xa;• At-least-once delivery" id="20">
