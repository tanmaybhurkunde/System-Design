                <UserObject label="&lt;font style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 36px;&quot;&gt;&lt;b&gt;👤 Client-Authoritative&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Client decides game state&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Architecture:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Client → Server (accepts)&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;📌 Example:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Client says &#39;I rolled 6&#39;&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Server accepts it&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;✅ Advantages:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Very simple&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Low server cost&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Easy to build&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;❌ Disadvantages:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Easy to cheat&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Clients send fake state&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Hard to maintain consistency&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;📊 Usage:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Old multiplayer games&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Small hobby projects&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Rarely used competitively&lt;/span&gt;&lt;/font&gt;" mermaidId="n:B" mermaidBaseStyle="html=1;whiteSpace=wrap;strokeWidth=2;fillColor=#0f3460;strokeColor=#e94560;fontColor=#ffffff;fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;" mermaidBaseValue="👤 Client-Authoritative&#xa;&#xa;Client decides game state&#xa;&#xa;Architecture:&#xa;Client → Server (accepts)&#xa;&#xa;📌 Example:&#xa;Client says &#39;I rolled 6&#39;&#xa;Server accepts it&#xa;&#xa;✅ Advantages:&#xa;• Very simple&#xa;• Low server cost&#xa;• Easy to build&#xa;&#xa;❌ Disadvantages:&#xa;• Easy to cheat&#xa;• Clients send fake state&#xa;• Hard to maintain consistency&#xa;&#xa;📊 Usage:&#xa;• Old multiplayer games&#xa;• Small hobby projects&#xa;• Rarely used competitively" id="14">
                    <mxCell style="html=1;whiteSpace=wrap;strokeWidth=2;fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;opacity=70;rounded=1;" vertex="1" parent="1">
                        <mxGeometry x="14620" y="1580" width="636" height="786" as="geometry"/>
                    </mxCell>
                </UserObject>
                <UserObject label="&lt;font style=&quot;&quot;&gt;&lt;b style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 36px;&quot;&gt;🛡️ Server-Authoritative&lt;br&gt;&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Server is the source of truth&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Architecture:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Client → Request → Server → Validate → Update State&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;📌 Example:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Player requests &#39;Move Pawn&#39;&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Server decides if valid&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;✅ Advantages:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Prevents cheating&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Strong consistency&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Easier recovery&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;❌ Disadvantages:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• More server resources&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Slightly higher latency&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;📊 Usage:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Ludo, Chess&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• PUBG, Valorant, Fortnite&lt;/span&gt;&lt;/font&gt;" mermaidId="n:C" mermaidBaseStyle="html=1;whiteSpace=wrap;strokeWidth=2;fillColor=#0f3460;strokeColor=#e94560;fontColor=#ffffff;fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;" mermaidBaseValue="🛡️ Server-Authoritative&#xa;&#xa;Server is the source of truth&#xa;&#xa;Architecture:&#xa;Client → Request → Server → Validate → Update State&#xa;&#xa;📌 Example:&#xa;Player requests &#39;Move Pawn&#39;&#xa;Server decides if valid&#xa;&#xa;✅ Advantages:&#xa;• Prevents cheating&#xa;• Strong consistency&#xa;• Easier recovery&#xa;&#xa;❌ Disadvantages:&#xa;• More server resources&#xa;• Slightly higher latency&#xa;&#xa;📊 Usage:&#xa;• Ludo, Chess&#xa;• PUBG, Valorant, Fortnite" id="15">
                    <mxCell style="html=1;whiteSpace=wrap;strokeWidth=2;fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;opacity=70;rounded=1;" vertex="1" parent="1">
                        <mxGeometry x="15500" y="1580" width="860" height="810" as="geometry"/>
                    </mxCell>
                </UserObject>
                <UserObject label="&lt;font style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 36px;&quot;&gt;&lt;b&gt;🤝 Peer-to-Peer (P2P)&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;No dedicated game server&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Architecture:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Player A ↔ Player B (Direct)&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;📌 Example:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Each player communicates directly&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;✅ Advantages:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Very cheap&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• No game-server infrastructure&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;❌ Disadvantages:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Cheating&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• NAT/firewall issues&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Host disconnect problems&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;📊 Usage:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Age of Empires&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Warcraft III&lt;/span&gt;&lt;/font&gt;" mermaidId="n:D" mermaidBaseStyle="html=1;whiteSpace=wrap;strokeWidth=2;fillColor=#0f3460;strokeColor=#e94560;fontColor=#ffffff;fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;" mermaidBaseValue="🤝 Peer-to-Peer (P2P)&#xa;&#xa;No dedicated game server&#xa;&#xa;Architecture:&#xa;Player A ↔ Player B (Direct)&#xa;&#xa;📌 Example:&#xa;Each player communicates directly&#xa;&#xa;✅ Advantages:&#xa;• Very cheap&#xa;• No game-server infrastructure&#xa;&#xa;❌ Disadvantages:&#xa;• Cheating&#xa;• NAT/firewall issues&#xa;• Host disconnect problems&#xa;&#xa;📊 Usage:&#xa;• Age of Empires&#xa;• Warcraft III" id="16">
                    <mxCell style="html=1;whiteSpace=wrap;strokeWidth=2;fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;opacity=70;rounded=1;" vertex="1" parent="1">
                        <mxGeometry x="16670" y="1665" width="697" height="736" as="geometry"/>
                    </mxCell>
                </UserObject>
                <UserObject label="&lt;font style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 36px;&quot;&gt;&lt;b&gt;👑 Host-Authoritative&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;One player acts as server&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Architecture:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Player A (Host) → B, C, D&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;📌 Example:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;If Player A leaves:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Game Ends&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• OR Host Migration occurs&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;✅ Advantages:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• No dedicated server cost&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;❌ Disadvantages:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Host dependency&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Migration issues&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;📊 Usage:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Many console multiplayer games&lt;/span&gt;&lt;/font&gt;" mermaidId="n:E" mermaidBaseStyle="html=1;whiteSpace=wrap;strokeWidth=2;fillColor=#0f3460;strokeColor=#e94560;fontColor=#ffffff;fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;" mermaidBaseValue="👑 Host-Authoritative&#xa;&#xa;One player acts as server&#xa;&#xa;Architecture:&#xa;Player A (Host) → B, C, D&#xa;&#xa;📌 Example:&#xa;If Player A leaves:&#xa;• Game Ends&#xa;• OR Host Migration occurs&#xa;&#xa;✅ Advantages:&#xa;• No dedicated server cost&#xa;&#xa;❌ Disadvantages:&#xa;• Host dependency&#xa;• Migration issues&#xa;&#xa;📊 Usage:&#xa;• Many console multiplayer games" id="17">
                    <mxCell style="html=1;whiteSpace=wrap;strokeWidth=2;fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;opacity=70;rounded=1;" vertex="1" parent="1">
                        <mxGeometry x="17560" y="1650" width="700" height="720" as="geometry"/>
                    </mxCell>
                </UserObject>
                <UserObject label="&lt;font style=&quot;&quot;&gt;&lt;b style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 36px;&quot;&gt;📡 Event-Driven&lt;br&gt;&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Services publish events&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Architecture:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Service A → Event Bus → Service B, Service C&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;📌 Example:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;GAME_FINISHED published to Kafka&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Consumers:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Leaderboard Service&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Analytics Service&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Notification Service&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;✅ Advantages:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Loose coupling&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Easy scaling&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Easy feature additions&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;❌ Disadvantages:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Complex debugging&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Eventual consistency&lt;/span&gt;&lt;/font&gt;" mermaidId="n:F" mermaidBaseStyle="html=1;whiteSpace=wrap;strokeWidth=2;fillColor=#0f3460;strokeColor=#e94560;fontColor=#ffffff;fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;" mermaidBaseValue="📡 Event-Driven&#xa;&#xa;Services publish events&#xa;&#xa;Architecture:&#xa;Service A → Event Bus → Service B, Service C&#xa;&#xa;📌 Example:&#xa;GAME_FINISHED published to Kafka&#xa;Consumers:&#xa;• Leaderboard Service&#xa;• Analytics Service&#xa;• Notification Service&#xa;&#xa;✅ Advantages:&#xa;• Loose coupling&#xa;• Easy scaling&#xa;• Easy feature additions&#xa;&#xa;❌ Disadvantages:&#xa;• Complex debugging&#xa;• Eventual consistency" id="18">
                    <mxCell style="html=1;whiteSpace=wrap;strokeWidth=2;fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;opacity=70;rounded=1;" vertex="1" parent="1">
                        <mxGeometry x="18470" y="1695" width="690" height="706" as="geometry"/>
                    </mxCell>
                </UserObject>
                <UserObject label="&lt;font style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 36px;&quot;&gt;&lt;b&gt;🔄 Request-Response&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Traditional web architecture&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Architecture:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Client → Request → Server → Response&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;📌 Example:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;GET /profile&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;✅ Advantages:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Simple&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Synchronous&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Easy to understand&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;❌ Disadvantages:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Blocking&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Not for real-time&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;📊 Usage:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• REST APIs&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Web applications&lt;/span&gt;&lt;/font&gt;" mermaidId="n:G" mermaidBaseStyle="html=1;whiteSpace=wrap;strokeWidth=2;fillColor=#0f3460;strokeColor=#e94560;fontColor=#ffffff;fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;" mermaidBaseValue="🔄 Request-Response&#xa;&#xa;Traditional web architecture&#xa;&#xa;Architecture:&#xa;Client → Request → Server → Response&#xa;&#xa;📌 Example:&#xa;GET /profile&#xa;&#xa;✅ Advantages:&#xa;• Simple&#xa;• Synchronous&#xa;• Easy to understand&#xa;&#xa;❌ Disadvantages:&#xa;• Blocking&#xa;• Not for real-time&#xa;&#xa;📊 Usage:&#xa;• REST APIs&#xa;• Web applications" id="19">
                    <mxCell style="html=1;whiteSpace=wrap;strokeWidth=2;fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;opacity=70;rounded=1;" vertex="1" parent="1">
