                <UserObject label="&lt;font style=&quot;font-size: 48px;&quot;&gt;&lt;b&gt;🏛️ System Architecture Patterns&lt;br&gt;&lt;br&gt;Different contexts, different meanings&lt;/b&gt;&lt;/font&gt;" mermaidId="n:A" mermaidBaseStyle="html=1;whiteSpace=wrap;strokeWidth=4;fillColor=#1a1a2e;strokeColor=#e94560;fontColor=#ffffff;fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;" mermaidBaseValue="🏛️ System Architecture Patterns&#xa;&#xa;Different contexts, different meanings" id="13">
                    <mxCell style="html=1;whiteSpace=wrap;strokeWidth=4;fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;opacity=70;rounded=1;" vertex="1" parent="1">
