                <UserObject label="&lt;font style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 36px;&quot;&gt;&lt;b&gt;🏢 Monolithic&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Everything in one app&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Architecture:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Ludo Application:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Auth&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Matchmaking&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Game Logic&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Leaderboard&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Single deployment&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;✅ Advantages:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Simpler&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Faster development&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Easy debugging&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;❌ Disadvantages:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Harder to scale&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Team coordination&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Technology lock-in&lt;/span&gt;&lt;/font&gt;" mermaidId="n:J" mermaidBaseStyle="html=1;whiteSpace=wrap;strokeWidth=2;fillColor=#0f3460;strokeColor=#e94560;fontColor=#ffffff;fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;" mermaidBaseValue="🏢 Monolithic&#xa;&#xa;Everything in one app&#xa;&#xa;Architecture:&#xa;Ludo Application:&#xa;• Auth&#xa;• Matchmaking&#xa;• Game Logic&#xa;• Leaderboard&#xa;Single deployment&#xa;&#xa;✅ Advantages:&#xa;• Simpler&#xa;• Faster development&#xa;• Easy debugging&#xa;&#xa;❌ Disadvantages:&#xa;• Harder to scale&#xa;• Team coordination&#xa;• Technology lock-in" id="22">
