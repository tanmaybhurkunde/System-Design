                <UserObject label="&lt;font style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 36px;&quot;&gt;&lt;b&gt;🎭 Actor Model&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Each room is an actor&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Architecture:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Room123 Actor:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Mailbox&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• State&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Logic&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Messages processed sequentially&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;📌 Example:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Move → Roll Dice → Disconnect → Reconnect&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;✅ Advantages:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Eliminates race conditions&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• High concurrency&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;❌ Disadvantages:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Complexity&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Message ordering&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;📊 Technologies:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;• Akka, Erlang, Orleans&lt;/span&gt;&lt;/font&gt;" mermaidId="n:L" mermaidBaseStyle="html=1;whiteSpace=wrap;strokeWidth=2;fillColor=#0f3460;strokeColor=#e94560;fontColor=#ffffff;fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;" mermaidBaseValue="🎭 Actor Model&#xa;&#xa;Each room is an actor&#xa;&#xa;Architecture:&#xa;Room123 Actor:&#xa;• Mailbox&#xa;• State&#xa;• Logic&#xa;Messages processed sequentially&#xa;&#xa;📌 Example:&#xa;Move → Roll Dice → Disconnect → Reconnect&#xa;&#xa;✅ Advantages:&#xa;• Eliminates race conditions&#xa;• High concurrency&#xa;&#xa;❌ Disadvantages:&#xa;• Complexity&#xa;• Message ordering&#xa;&#xa;📊 Technologies:&#xa;• Akka, Erlang, Orleans" id="24">
